# Database (Railway PostgreSQL)
DATABASE_URL=postgres://user:password@host:5432/dbname

# Payload CMS
# Generate with: openssl rand -base64 32
# Minimum 32 characters, cryptographically random
PAYLOAD_SECRET=CHANGE-ME-GENERATE-WITH-OPENSSL-RAND

# Site URL (no trailing slash)
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# S3-Compatible Storage (Railway Object Storage)
S3_BUCKET=evchurch-media
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=
S3_REGION=auto
S3_ENDPOINT=

# Rock RMS API
ROCK_API_URL=https://rock.ev.church/api
ROCK_API_KEY=

# Rock Webhook Security
# Shared secret for HMAC-SHA256 webhook validation
ROCK_WEBHOOK_SECRET=

# Preview Mode
# Generate with: openssl rand -base64 32
PREVIEW_SECRET=

# Cron Sync Trigger
# Protects the /api/sync/trigger endpoint
CRON_SECRET=

# Google Maps
GOOGLE_MAPS_API_KEY=

# Google Analytics
NEXT_PUBLIC_GA_ID=G-1R09W3HMNX
